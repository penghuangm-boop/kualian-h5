# Local API
NODE_ENV=development
PORT=4174
HOST=127.0.0.1
DATA_DIR=./data
KUAILIAN_DB_PATH=./data/kuailian.sqlite
PUBLIC_BASE_URL=http://127.0.0.1:4173

# WeChat Official Account OAuth
# mock: local development without WeChat credentials
# wechat: real official-account OAuth after the公众号 is ready
WECHAT_MODE=mock
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=

# WeChat Pay JSAPI
# mock: local development returns a simulated paid order
# wechat_jsapi: real JSAPI order creation after the商户号 is ready
WECHAT_PAY_MODE=mock
WECHAT_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_PRODUCT_NAME=7 天状态管理
WECHAT_PAY_AMOUNT_CENTS=990
